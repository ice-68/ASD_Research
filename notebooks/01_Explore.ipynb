    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import numpy as np\\n\",\n",
    "    \"from src.dataset import load_raw_data\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 获取数据\\n\",\n",
    "    \"data, labels = load_raw_data()\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 选取第一个 ASD 样本和第一个 Control 样本进行对比\\n\",\n",
    "    \"asd_sample = data[labels.index(1)]\\n\",\n",
    "    \"ctrl_sample = data[labels.index(0)]\\n\",\n",
    "    \"\\n\",\n",
    "    \"def plot_corr_matrix(ts, title):\\n\",\n",
    "    \"    corr = np.corrcoef(ts.T) # 计算 116x116 的相关矩阵\\n\",\n",
    "    \"    plt.figure(figsize=(8, 6))\\n\",\n",
    "    \"    sns.heatmap(corr, cmap='coolwarm', center=0)\\n\",\n",
    "    \"    plt.title(title)\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"plot_corr_matrix(asd_sample, \\\"ASD Subject Pearson Matrix\\\")\\n\",\n",
    "    \"plot_corr_matrix(ctrl_sample, \\\"Control Subject Pearson Matrix\\\")\"\n",
    "   ],\n",
