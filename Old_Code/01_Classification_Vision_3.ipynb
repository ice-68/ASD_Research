    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"# 训练完成后，开始可视化\\n\",\n",
    "    \"plt.figure(figsize=(12, 5))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 子图1：Loss 下降情况\\n\",\n",
    "    \"plt.subplot(1, 2, 1)\\n\",\n",
    "    \"plt.plot(train_losses, label='Train Loss', color='red')\\n\",\n",
