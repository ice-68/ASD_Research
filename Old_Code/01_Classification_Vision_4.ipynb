    "   \"source\": [\n",
    "    \"plt.figure(figsize=(14, 6))\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 为了画平均线，我们需要知道最长训练了多少 epoch（处理某些 fold 提前早停的情况）\\n\",\n",
    "    \"max_epochs = max(len(h['train_loss']) for h in all_fold_histories)\\n\",\n",
    "    \"epochs_range = np.arange(1, max_epochs + 1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 初始化用于计算平均值的矩阵（用 NaN 填充，方便处理早停导致长度不一的情况）\\n\",\n",
    "    \"all_train_losses = np.full((5, max_epochs), np.nan)\\n\",\n",
    "    \"all_val_losses = np.full((5, max_epochs), np.nan)\\n\",\n",
    "    \"all_train_accs = np.full((5, max_epochs), np.nan)\\n\",\n",
    "    \"all_val_accs = np.full((5, max_epochs), np.nan)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ----------------- 1. 绘制每个 Fold 的细线 -----------------\\n\",\n",
    "    \"for idx, h in enumerate(all_fold_histories):\\n\",\n",
    "    \"    cur_epochs = len(h['train_loss'])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 存入矩阵用于后续算平均\\n\",\n",
    "    \"    all_train_losses[idx, :cur_epochs] = h['train_loss']\\n\",\n",
    "    \"    all_val_losses[idx, :cur_epochs] = h['val_loss']\\n\",\n",
    "    \"    all_train_accs[idx, :cur_epochs] = h['train_acc']\\n\",\n",
    "    \"    all_val_accs[idx, :cur_epochs] = h['val_acc']\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 子图 1：Loss\\n\",\n",
    "    \"    plt.subplot(1, 2, 1)\\n\",\n",
    "    \"    plt.plot(range(1, cur_epochs+1), h['train_loss'], color='blue', alpha=0.15, linestyle='--')\\n\",\n",
    "    \"    plt.plot(range(1, cur_epochs+1), h['val_loss'], color='red', alpha=0.15, linestyle='--')\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 子图 2：Accuracy\\n\",\n",
    "    \"    plt.subplot(1, 2, 2)\\n\",\n",
    "    \"    plt.plot(range(1, cur_epochs+1), h['train_acc'], color='blue', alpha=0.15, linestyle='--')\\n\",\n",
    "    \"    plt.plot(range(1, cur_epochs+1), h['val_acc'], color='red', alpha=0.15, linestyle='--')\\n\",\n",
    "    \"\\n\",\n",
    "    \"# ----------------- 2. 计算并绘制 5 折平均粗线 -----------------\\n\",\n",
    "    \"# 使用 np.nanmean 忽略早停后的空白处\\n\",\n",
    "    \"mean_train_loss = np.nanmean(all_train_losses, axis=0)\\n\",\n",
    "    \"mean_val_loss = np.nanmean(all_val_losses, axis=0)\\n\",\n",
    "    \"mean_train_acc = np.nanmean(all_train_accs, axis=0)\\n\",\n",
    "    \"mean_val_acc = np.nanmean(all_val_accs, axis=0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 子图 1：Loss 完美的平均曲线\\n\",\n",
    "    \"plt.subplot(1, 2, 1)\\n\",\n",
    "    \"plt.plot(epochs_range, mean_train_loss, 'b-', linewidth=2, label='Mean Train Loss')\\n\",\n",
    "    \"plt.plot(epochs_range, mean_val_loss, 'r-', linewidth=2, label='Mean Val Loss')\\n\",\n",
    "    \"plt.title('5-Fold Cross Validation: Loss')\\n\",\n",
    "    \"plt.xlabel('Epochs')\\n\",\n",
    "    \"plt.ylabel('Loss')\\n\",\n",
    "    \"plt.legend()\\n\",\n",
    "    \"plt.grid(True, alpha=0.3)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 子图 2：Accuracy 完美的平均曲线\\n\",\n",
    "    \"plt.subplot(1, 2, 2)\\n\",\n",
    "    \"plt.plot(epochs_range, mean_train_acc, 'b-', linewidth=2, label='Mean Train Acc')\\n\",\n",
    "    \"plt.plot(epochs_range, mean_val_acc, 'r-', linewidth=2, label='Mean Val Acc')\\n\",\n",
    "    \"plt.title('5-Fold Cross Validation: Accuracy')\\n\",\n",
    "    \"plt.xlabel('Epochs')\\n\",\n",
    "    \"plt.ylabel('Accuracy')\\n\",\n",
    "    \"plt.legend()\\n\",\n",
