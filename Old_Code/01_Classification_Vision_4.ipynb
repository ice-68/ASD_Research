    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": [\n",
    "    \"# 基于 ABIDE 数据集的脑功能网络分类 (GCN Pro)\\n\",\n",
    "    \"本 Notebook 实现了基于 PyTorch Geometric 的图卷积网络，包含以下特性：\\n\",\n",
    "    \"1. **Stratified 5-Fold 交叉验证**：确保小样本下的泛化性能评估。\\n\",\n",
    "    \"2. **早停机制 (Early Stopping)**：监控验证集，防止过拟合。\\n\",\n",
    "    \"3. **混合池化与边权重**：结合 Mean/Max Pooling 并利用皮尔逊相关系数作为边权重。\"\n",
    "   ],\n",
    "   \"id\": \"207c97360a2da98b\"\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"id\": \"initial_id\",\n",
    "   \"metadata\": {\n",
    "    \"collapsed\": true,\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-06-14T03:30:16.295844Z\",\n",
    "     \"start_time\": \"2026-06-14T03:30:16.276326900Z\"\n",
    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"import torch\\n\",\n",
    "    \"import torch.nn.functional as F\\n\",\n",
    "    \"from torch.nn import Linear, BatchNorm1d\\n\",\n",
    "    \"from torch_geometric.loader import DataLoader\\n\",\n",
    "    \"from torch_geometric.data import Data\\n\",\n",
    "    \"from torch_geometric.nn import GCNConv, global_mean_pool, global_max_pool\\n\",\n",
    "    \"from sklearn.model_selection import StratifiedKFold\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import copy\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 检查设备环境\\n\",\n",
    "    \"device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\\n\",\n",
    "    \"print(f\\\"当前使用计算设备: {device}\\\")\\n\",\n",
    "    \"if device.type == 'cuda':\\n\",\n",
    "    \"    print(f\\\"显卡型号: {torch.cuda.get_device_name(0)}\\\")\"\n",
    "   ],\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"当前使用计算设备: cuda\\n\",\n",
    "      \"显卡型号: NVIDIA GeForce RTX 5060 Laptop GPU\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 26\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-06-14T03:30:19.001426900Z\",\n",
    "     \"start_time\": \"2026-06-14T03:30:16.303842400Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import os\\n\",\n",
    "    \"import glob\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import re\\n\",\n",
    "    \"\\n\",\n",
    "    \"csv_path = r\\\"C:\\\\Users\\\\28439\\\\Desktop\\\\ASD\\\\abide_data\\\\ABIDE_pcp\\\\Phenotypic_V1_0b_preprocessed1.csv\\\"\\n\",\n",
    "    \"phenotype_df = pd.read_csv(csv_path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"folder_path = r'C:\\\\Users\\\\28439\\\\Desktop\\\\ASD\\\\abide_data\\\\ABIDE_pcp\\\\cpac\\\\nofilt_noglobal'\\n\",\n",
    "    \"file_list = glob.glob(os.path.join(folder_path, '*.1D'))\\n\",\n",
    "    \"\\n\",\n",
    "    \"matched_all_time_series = []\\n\",\n",
    "    \"matched_labels = []\\n\",\n",
    "    \"nan_samples = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"success_count = 0\\n\",\n",
    "    \"fail_count = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"for file_path in file_list:\\n\",\n",
    "    \"    filename = os.path.basename(file_path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 提取 SUB_ID\\n\",\n",
    "    \"    match = re.search(r'\\\\d{5,7}', filename)\\n\",\n",
    "    \"    if not match:\\n\",\n",
    "    \"        print(f\\\"无法从文件名中提取数字 ID: {filename}\\\")\\n\",\n",
    "    \"        continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"    sub_id = int(match.group())\\n\",\n",
    "    \"    subject_row = phenotype_df[phenotype_df['SUB_ID'] == sub_id]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if not subject_row.empty:\\n\",\n",
    "    \"\\n\",\n",
    "    \"        time_series = np.loadtxt(file_path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        noise = np.random.normal(0, 1e-5, size=time_series.shape)\\n\",\n",
    "    \"        ts_fixed = time_series + noise\\n\",\n",
    "    \"\\n\",\n",
    "    \"        matrix = np.corrcoef(ts_fixed, rowvar=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if np.isnan(matrix).any():\\n\",\n",
    "    \"            nan_samples.append(success_count)\\n\",\n",
    "    \"            matrix = np.nan_to_num(matrix)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        label = subject_row['DX_GROUP'].values[0]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        matched_all_time_series.append(matrix)\\n\",\n",
    "    \"        matched_labels.append(label - 1)  # 1,2 变 0,1，为了能在Tensor训练，不然标签对不上。\\n\",\n",
    "    \"\\n\",\n",
    "    \"        success_count += 1\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        fail_count += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"结束。成功: {success_count} 个，失败: {fail_count} 个。\\\")\\n\",\n",
    "    \"print(f\\\"包含 NaN 的样本总数: {len(nan_samples)} / {len(matched_all_time_series)}\\\")\\n\",\n",
    "    \"if len(nan_samples) > 0:\\n\",\n",
    "    \"    print(f\\\"具体有问题的样本索引: {nan_samples}\\\")\"\n",
    "   ],\n",
    "   \"id\": \"76531d32f572952d\",\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"结束。成功: 871 个，失败: 0 个。\\n\",\n",
    "      \"包含 NaN 的样本总数: 0 / 871\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 27\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-06-14T03:30:19.030475400Z\",\n",
    "     \"start_time\": \"2026-06-14T03:30:19.002426900Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"nan_samples = []\\n\",\n",
    "    \"for i in range(len(matched_all_time_series)):\\n\",\n",
    "    \"    if np.isnan(matched_all_time_series[i]).any():\\n\",\n",
    "    \"        nan_samples.append(i)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"包含 NaN 的样本总数: {len(nan_samples)} / {len(matched_all_time_series)}\\\")\\n\",\n",
    "    \"print(f\\\"具体有问题的样本索引: {nan_samples}\\\")\"\n",
    "   ],\n",
    "   \"id\": \"ad509174a738c7ae\",\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"包含 NaN 的样本总数: 0 / 871\\n\",\n",
    "      \"具体有问题的样本索引: []\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 28\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-06-14T03:30:19.612041600Z\",\n",
    "     \"start_time\": \"2026-06-14T03:30:19.031474500Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"# 构造 PyG Data 对象列表\\n\",\n",
    "    \"data_list = []\\n\",\n",
    "    \"threshold = 0.3  # 边过滤阈值\\n\",\n",
    "    \"total_isolated_nodes = 0\\n\",\n",
    "    \"\\n\",\n",
    "    \"for matrix, label in zip(matched_all_time_series, matched_labels):\\n\",\n",
    "    \"    # 1. 节点特征\\n\",\n",
    "    \"    x = torch.tensor(matrix, dtype=torch.float)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 2. 边提取与边权重\\n\",\n",
    "    \"    adj_matrix = np.where(np.abs(matrix) > threshold, matrix, 0)\\n\",\n",
    "    \"    np.fill_diagonal(adj_matrix, 0)\\n\",\n",
    "    \"    adj_matrix = np.where(np.abs(adj_matrix) > threshold, adj_matrix, 0)\\n\",\n",
    "    \"    rows, cols = np.nonzero(adj_matrix)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 如果这个病人连一条边都没有(极度罕见)，跳过或者特殊处理\\n\",\n",
    "    \"    if len(rows) == 0:\\n\",\n",
    "    \"        print(f\\\"Warning: 发现全空图 (Label: {label})，已跳过\\\")\\n\",\n",
    "    \"        continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"    edge_index = torch.tensor(np.array([rows, cols]), dtype=torch.long)\\n\",\n",
    "    \"    edge_weight = adj_matrix[rows, cols]\\n\",\n",
    "    \"    edge_attr = torch.tensor(np.abs(edge_weight), dtype=torch.float)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    y = torch.tensor([label], dtype=torch.long)\\n\",\n",
    "    \"    data = Data(x=x, edge_index=edge_index, edge_attr=edge_attr, y=y)\\n\",\n",
    "    \"    connected_nodes = torch.unique(edge_index)\\n\",\n",
    "    \"    if len(connected_nodes) < matrix.shape[0]:\\n\",\n",
    "    \"        isolated_count = matrix.shape[0] - len(connected_nodes)\\n\",\n",
    "    \"        total_isolated_nodes += isolated_count\\n\",\n",
    "    \"    data_list.append(data)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# 提取用于 K-Fold 分层的标签\\n\",\n",
    "    \"labels = [data.y.item() for data in data_list]\\n\",\n",
    "    \"print(f\\\"总计构建图样本数: {len(data_list)}\\\")\"\n",
    "   ],\n",
    "   \"id\": \"9083f25432674048\",\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"总计构建图样本数: 871\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 29\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-06-14T03:30:19.636817600Z\",\n",
    "     \"start_time\": \"2026-06-14T03:30:19.613101700Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"class BrainGCNPro(torch.nn.Module):\\n\",\n",
    "    \"    def __init__(self, num_node_features, hidden_channels =16, num_classes=2):\\n\",\n",
    "    \"        super(BrainGCNPro, self).__init__()\\n\",\n",
    "    \"        torch.manual_seed(32)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # GCN 层\\n\",\n",
    "    \"        self.conv1 = GCNConv(num_node_features, hidden_channels)\\n\",\n",
    "    \"        self.conv2 = GCNConv(hidden_channels, hidden_channels)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # BN 层\\n\",\n",
    "    \"        self.bn1 = BatchNorm1d(hidden_channels)\\n\",\n",
    "    \"        self.bn2 = BatchNorm1d(hidden_channels)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 分类头 (输入维度翻倍是因为拼接了 Mean 和 Max Pooling)\\n\",\n",
    "    \"        self.lin1 = Linear(116 * hidden_channels, 64)\\n\",\n",
    "    \"        self.lin2 = Linear(64, num_classes)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def forward(self, x, edge_index, edge_attr, batch):\\n\",\n",
    "    \"        # Layer 1\\n\",\n",
    "    \"        x1 = self.conv1(x, edge_index, edge_weight=edge_attr)\\n\",\n",
    "    \"        x1 = self.bn1(x1)\\n\",\n",
    "    \"        x1 = F.relu(x1)\\n\",\n",
    "    \"        x1 = F.dropout(x1, p=0.4, training=self.training)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Layer 2\\n\",\n",
    "    \"        x2 = self.conv2(x1, edge_index, edge_weight=edge_attr)\\n\",\n",
    "    \"        x2 = self.bn2(x2)\\n\",\n",
    "    \"        x2 = F.relu(x2)\\n\",\n",
    "    \"        x2 = F.dropout(x2, p=0.4, training=self.training)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Readout: 混合池化\\n\",\n",
    "    \"        x_out = x1 + x2\\n\",\n",
    "    \"        batch_size = int(batch.max()) + 1\\n\",\n",
    "    \"        x_flat = x_out.view(batch_size, -1)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # MLP Head\\n\",\n",
    "    \"        out = F.dropout(x_flat, p=0.5, training=self.training)\\n\",\n",
    "    \"        out = F.relu(self.lin1(out))\\n\",\n",
    "    \"        out = F.dropout(out, p=0.2, training=self.training)\\n\",\n",
    "    \"        out = self.lin2(out)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return out\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"模型架构 BrainGCNPro 定义完成。\\\")\"\n",
    "   ],\n",
    "   \"id\": \"3dadf0c33deaaf8d\",\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"模型架构 BrainGCNPro 定义完成。\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 30\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-06-14T03:30:27.387991500Z\",\n",
    "     \"start_time\": \"2026-06-14T03:30:19.637825800Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"from sklearn.svm import SVC\\n\",\n",
    "    \"from sklearn.model_selection import StratifiedKFold\\n\",\n",
    "    \"from sklearn.metrics import accuracy_score\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"X_flat = []\\n\",\n",
    "    \"for matrix in matched_all_time_series:\\n\",\n",
    "    \"    upper_tri_idx = np.triu_indices_from(matrix, k=1)\\n\",\n",
    "    \"    X_flat.append(matrix[upper_tri_idx])\\n\",\n",
    "    \"\\n\",\n",
    "    \"X_flat = np.array(X_flat)\\n\",\n",
    "    \"Y = np.array(matched_labels)\\n\",\n",
    "    \"skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\\n\",\n",
    "    \"svm_accs = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"for train_idx, val_idx in skf.split(X_flat, Y):\\n\",\n",
    "    \"    clf = SVC(kernel='rbf', C=1.0)\\n\",\n",
    "    \"    clf.fit(X_flat[train_idx], Y[train_idx])\\n\",\n",
    "    \"    preds = clf.predict(X_flat[val_idx])\\n\",\n",
    "    \"    svm_accs.append(accuracy_score(Y[val_idx], preds))\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"SVM Baseline 平均准确率: {np.mean(svm_accs):.4f}\\\")\"\n",
    "   ],\n",
    "   \"id\": \"648a4fc9df83dd66\",\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"name\": \"stdout\",\n",
    "     \"output_type\": \"stream\",\n",
    "     \"text\": [\n",
    "      \"SVM Baseline 平均准确率: 0.6257\\n\"\n",
    "     ]\n",
    "    }\n",
    "   ],\n",
    "   \"execution_count\": 31\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-06-14T03:30:54.980095300Z\",\n",
    "     \"start_time\": \"2026-06-14T03:30:27.388991900Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"k_folds = 5\\n\",\n",
    "    \"skf = StratifiedKFold(n_splits=k_folds, shuffle=True, random_state=42)\\n\",\n",
    "    \"\\n\",\n",
    "    \"fold_results = []  # 记录每折最佳准确率\\n\",\n",
    "    \"# ====== 修改1：创建更完善的历史记录字典，方便后续画图 ======\\n\",\n",
    "    \"all_fold_histories = []\\n\",\n",
    "    \"\\n\",\n",
    "    \"for fold, (train_idx, val_idx) in enumerate(skf.split(np.zeros(len(labels)), labels)):\\n\",\n",
    "    \"    print(f\\\"\\\\n{'='*15} 🚀 启动 Fold {fold + 1} {'='*15}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    train_subset = [data_list[i] for i in train_idx]\\n\",\n",
    "    \"    val_subset = [data_list[i] for i in val_idx]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    train_loader = DataLoader(train_subset, batch_size=32, shuffle=True)\\n\",\n",
    "    \"    val_loader = DataLoader(val_subset, batch_size=32, shuffle=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    num_features = train_subset[0].x.shape[1]\\n\",\n",
    "    \"    model = BrainGCNPro(num_node_features=num_features, hidden_channels=64).to(device)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 优化器与调度器\\n\",\n",
    "    \"    optimizer = torch.optim.Adam(model.parameters(), lr=0.001, weight_decay=1e-2)\\n\",\n",
    "    \"    criterion = torch.nn.CrossEntropyLoss()\\n\",\n",
    "    \"    scheduler = torch.optim.lr_scheduler.ReduceLROnPlateau(optimizer, mode='min', factor=0.5, patience=5)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 早停配置\\n\",\n",
    "    \"    patience = 15\\n\",\n",
    "    \"    patience_counter = 0\\n\",\n",
    "    \"    best_val_loss = float('inf')\\n\",\n",
    "    \"    best_val_acc = 0.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # ====== 修改2：初始化当前 Fold 的完整四项历史记录 ======\\n\",\n",
    "    \"    history = {\\n\",\n",
    "    \"        'train_loss': [], 'train_acc': [],\\n\",\n",
    "    \"        'val_loss': [], 'val_acc': []\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    for epoch in range(1, 101):\\n\",\n",
    "    \"        # ------------------ 训练阶段 ------------------\\n\",\n",
    "    \"        model.train()\\n\",\n",
    "    \"        train_loss = 0\\n\",\n",
    "    \"        train_correct = 0  # 🌟 新增：用于统计训练集正确预测数\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for data in train_loader:\\n\",\n",
    "    \"            data = data.to(device)\\n\",\n",
    "    \"            optimizer.zero_grad()\\n\",\n",
    "    \"            out = model(data.x, data.edge_index, data.edge_attr, data.batch)\\n\",\n",
    "    \"            loss = criterion(out, data.y)\\n\",\n",
    "    \"            loss.backward()\\n\",\n",
    "    \"            optimizer.step()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            train_loss += loss.item() * data.num_graphs\\n\",\n",
    "    \"            pred = out.argmax(dim=-1)\\n\",\n",
    "    \"            train_correct += int((pred == data.y).sum())\\n\",\n",
    "    \"\\n\",\n",
    "    \"        train_loss /= len(train_subset)\\n\",\n",
    "    \"        train_acc = train_correct / len(train_subset)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # ------------------ 验证阶段 ------------------\\n\",\n",
    "    \"        model.eval()\\n\",\n",
    "    \"        val_loss = 0\\n\",\n",
    "    \"        val_correct = 0\\n\",\n",
    "    \"        with torch.no_grad():\\n\",\n",
    "    \"            for data in val_loader:\\n\",\n",
    "    \"                data = data.to(device)\\n\",\n",
    "    \"                out = model(data.x, data.edge_index, data.edge_attr, data.batch)\\n\",\n",
    "    \"                loss = criterion(out, data.y)\\n\",\n",
    "    \"                val_loss += loss.item() * data.num_graphs\\n\",\n",
    "    \"                pred = out.argmax(dim=-1)\\n\",\n",
    "    \"                val_correct += int((pred == data.y).sum())\\n\",\n",
    "    \"\\n\",\n",
    "    \"        val_loss /= len(val_subset)\\n\",\n",
    "    \"        val_acc = val_correct / len(val_subset)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # ====== 修改3：将四项核心指标存入历史记录 ======\\n\",\n",
    "    \"        history['train_loss'].append(train_loss)\\n\",\n",
    "    \"        history['train_acc'].append(train_acc)\\n\",\n",
    "    \"        history['val_loss'].append(val_loss)\\n\",\n",
    "    \"        history['val_acc'].append(val_acc)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        scheduler.step(val_loss)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 早停判断\\n\",\n",
    "    \"        if val_loss < best_val_loss:\\n\",\n",
    "    \"            best_val_loss = val_loss\\n\",\n",
    "    \"            best_val_acc = val_acc\\n\",\n",
    "    \"            patience_counter = 0\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            patience_counter += 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # ====== 修改4：完美对齐打印训练集与验证集的指标 ======\\n\",\n",
    "    \"        if epoch % 5 == 0 or epoch == 1:  # 改为每 5 轮打印一次，观察更细腻\\n\",\n",
    "    \"            print(f'Epoch {epoch:03d} | '\\n\",\n",
    "    \"                  f'Train Loss: {train_loss:.4f} | Train Acc: {train_acc:.4f} || '\\n\",\n",
    "    \"                  f'Val Loss: {val_loss:.4f} | Val Acc: {val_acc:.4f}')\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if patience_counter >= patience:\\n\",\n",
    "    \"            print(f\\\"触发早停: Epoch {epoch} (连续 {patience} 次验证集 Loss 未下降)\\\")\\n\",\n",
    "    \"            break\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(f\\\" Fold {fold + 1} 结束，锁定最佳验证集准确率: {best_val_acc:.4f}\\\")\\n\",\n",
    "    \"    fold_results.append(best_val_acc)\\n\",\n",
    "    \"    all_fold_histories.append(history)  # 存储本折的全部历史数据\\n\",\n",
    "    \"\\n\",\n",
